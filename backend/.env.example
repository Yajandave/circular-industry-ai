# Circular Industry AI optional LLM reasoning layer
# Keep API keys in backend/.env only. Do not commit real keys.

# Default safe mode: no live LLM calls.
AI_REASONING_ENABLED=false

# Gemini free-tier setup through Google AI Studio.
LLM_PROVIDER=gemini
GEMINI_API_KEY=
OPENAI_MODEL=gemini-2.5-flash
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# OpenAI setup, if you later switch provider.
# LLM_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-5-mini
# OPENAI_REASONING_EFFORT=low
